{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "group:recommended"
  ],
  "ignorePresets": [
    ":prHourlyLimit2"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "groupName": "wreq packages",
      "matchPackageNames": ["wreq", "wreq-util"]
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  }
}
